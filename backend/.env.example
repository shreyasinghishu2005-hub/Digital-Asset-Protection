# Copy to .env and fill in (never commit .env)

# Google AI Studio / Gemini API — enables contextual assistant narratives (server-side only)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Comma-separated browser origins allowed to call the API (default: local Vite)
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Max upload size in bytes (default 26214400 = 25 MiB)
# MAX_UPLOAD_BYTES=26214400
